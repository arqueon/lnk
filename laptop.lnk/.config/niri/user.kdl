// ═══ user.kdl (POR-HOST: laptop) ═══
// Solo lo específico de laptop; lo compartido vive en user-common.kdl.
// Nota: Mod+D (antes anyrun) quedó libre; overview = Mod+E.

window-rule {
    match app-id="google-chrome"
    default-column-width { proportion 1.0; }
    opacity 1.0
    open-focused true
}

window-rule {
    match app-id="firefox"
    default-column-width { proportion 0.7; }
    opacity 1.0
    open-focused true
}

environment {
    CHROME_EXECUTABLE "google-chrome-beta" // en laptop se usa Chrome Beta
}
