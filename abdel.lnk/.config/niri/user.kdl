// ═══ user.kdl (POR-HOST: abdel) ═══
// Solo lo específico de abdel; lo compartido vive en user-common.kdl.
// Nota: Mod+D (antes anyrun) quedó libre; overview = Mod+E.

window-rule {
    match app-id="google-chrome"
    default-column-width { proportion 0.9; }
    opacity 1.0
    open-focused true
}

window-rule {
    match app-id="firefox"
    default-column-width { proportion 0.7; }
    open-focused true
}

binds {
    Mod+Alt+Return { spawn-sh "nemo ~/Downloads/"; } // abdel usa nemo, no thunar
}
