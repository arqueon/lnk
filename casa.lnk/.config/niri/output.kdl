// ═══ output.kdl (POR-HOST: casa) ═══
// Monitores físicos de este equipo. DP-2 = Sceptre O34 ultrawide
// (principal, a la derecha); HDMI-A-1 = Sceptre F27 (secundario,
// a la izquierda). Las barras DMS se asignan por monitor en
// ~/.config/DankMaterialShell/settings.json (screenPreferences).

output "DP-2" {
    mode "3440x1440@165.001"
    scale 1.22
    position x=1920 y=0
}

output "HDMI-A-1" {
    mode "1920x1080@60.000"
    scale 1.0
    position x=0 y=0
}
