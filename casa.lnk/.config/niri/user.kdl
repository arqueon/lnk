// ═══ user.kdl (POR-HOST: casa) ═══
// Solo lo específico de casa; lo compartido vive en user-common.kdl.
// Último include de config.kdl: gana a todo.

// ── Window rules propias (anchos para el ultrawide DP-2) ──
window-rule {
    match app-id="google-chrome"
    default-column-width { proportion 0.5; }
    open-focused true
}

window-rule {
    match app-id="firefox"
    default-column-width { proportion 0.5; }
    open-focused true
}

window-rule {
    match app-id=r#"^(firefox|org\.mozilla\.firefox)(-.*)?$"#
    match app-id=r#"^google-chrome(-.*)?$"#
    match app-id=r#"^com\.google\.Chrome(-.*)?$"#
    open-on-workspace "web"
}


// ── Binds propios ──
binds {
    Mod+D { spawn "dmail" "show"; } // notificador de correo dankmail (solo casa)
}
