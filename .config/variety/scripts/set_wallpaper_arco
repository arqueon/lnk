#!/bin/bash

WP=$1
cp "$WP" ~/wallpaper/default.jpg
chmod 644 ~/wallpaper/default.jpg

# =============================================================================
# BLOQUE ESPECÍFICO POR ENTORNO
# =============================================================================
if [ "$XDG_CURRENT_DESKTOP" == "Niri" ]; then
    # Generar colores en modo dark de forma SÍNCRONA antes de que DMS
    # dispare su propio matugen async al hacer wallpaper set.
    # Así cuando wallpaper set termine, los colores ya están en dark.
    dms matugen generate --value "$WP" --mode dark

    # En DMS 1.5 podemos usar el comando global para establecer el wallpaper,
    # lo que soluciona el problema de que al apagarse un monitor y volver a encenderse
    # se quede sin fondo, ya que 'set' define el wallpaper por defecto para todas las pantallas presentes y futuras.
    dms ipc wallpaper set "$WP"

    dms ipc settings set greeterWallpaperPath /home/ruben/wallpaper/default.jpg
elif [ "$XDG_CURRENT_DESKTOP" == "qtile" ] || [ "$DESKTOP_SESSION" == "qtile" ]; then
    matugen image "$WP" -t scheme-kde > ~/.local/share/color-schemes/DankMatugen.colors
    qtile cmd-obj -o cmd -f reload_config
fi

sleep 1
# Reforzar tema dark al final, después de que cualquier proceso async de DMS haya terminado
if [ "$XDG_CURRENT_DESKTOP" == "Niri" ]; then
    dms ipc theme dark
    # Propagar el tema a las aplicaciones (GTK/Qt/KDE/fontconfig/XSettings) mediante
    # el plugin dmsThemeSync, que es ahora la fuente única de sincronización de tema.
    dms ipc call dmsThemeSync apply
fi

# =============================================================================
# BLOQUE DE TEMA DESACTIVADO — ahora lo gestiona el plugin dmsThemeSync.
# Se conserva comentado como referencia; NO borrar. Reactivar quitando los '#'.
# =============================================================================
# # Obtener fuentes, iconos y cursor desde DMS settings.json de forma dinámica
# DMS_SETTINGS="$HOME/.config/DankMaterialShell/settings.json"
# if [ -f "$DMS_SETTINGS" ] && command -v jq >/dev/null 2>&1; then
#     MONO_FONT=$(jq -r '.monoFontFamily // empty' "$DMS_SETTINGS")
#     PROP_FONT=$(jq -r '.fontFamily // empty' "$DMS_SETTINGS")
#     ICON_THEME=$(jq -r '.iconTheme // empty' "$DMS_SETTINGS")
#     CURSOR_THEME=$(jq -r '.cursorSettings.theme // empty' "$DMS_SETTINGS")
# fi
#
# MONO_FONT=${MONO_FONT:-"FantasqueSansM Nerd Font Mono"}
# PROP_FONT=${PROP_FONT:-"Fira Sans"}
# ICON_THEME=${ICON_THEME:-"Papirus-Dark"}
# CURSOR_THEME=${CURSOR_THEME:-"oreo_teal_cursors"}
#
# # Generar/actualizar fonts.conf de fontconfig dinámicamente
# cat <<EOF > "$HOME/.config/fontconfig/fonts.conf"
# <?xml version='1.0'?>
