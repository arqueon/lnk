binds {
    // General actions and system commands
    Mod+Shift+Slash { show-hotkey-overlay; }
    Mod+E { toggle-overview; }
    Mod+Q { close-window; }
    Mod+Shift+E { quit; }
    Mod+Shift+P { power-off-monitors; }
    Mod+Ctrl+Shift+F { toggle-windowed-fullscreen; }
    Mod+Ctrl+Shift+S { toggle-keyboard-shortcuts-inhibit; }

    // Application launchers and binds
        Mod+D { spawn "anyrun"; }
    Mod+Return { spawn "kitty"; }
    Mod+Shift+Z { spawn "nemo"; }
    Mod+Shift+Return { spawn-sh "thunar"; }
    Mod+F1 { spawn-sh "~/.config/niri/scripts/run_chrome.sh"; }
    Mod+Alt+F1 { spawn-sh "firefox"; }
    Mod+F2 { spawn "ferdium"; }
    Mod+F3 { spawn "zotero"; }
    Mod+F4 { spawn "logseq"; }
    Mod+F5 { spawn "zettlr"; }
    Mod+F6 { spawn "krusader"; }
    Mod+F7 { spawn "virt-manager"; }
    Mod+F8 { spawn "qbittorrent"; }
    Mod+F9 { spawn "jdownloader"; }
    Mod+F10 { spawn "~/.config/niri/scripts/launch-anytype.sh"; }
    Mod+Alt+F10 { spawn "claude-desktop"; }
    Mod+F11 { spawn "github-desktop"; }
    Mod+Alt+F11 { spawn "antigravity-ide"; }
    Mod+F12 { spawn "smile"; }
    Mod+Ctrl+N { spawn "newsflash"; }
    Mod+Ctrl+M { spawn-sh "~/.config/niri/scripts/run_stream.sh"; }

    // System utility binds
    Mod+L allow-when-locked=true hotkey-overlay-title="Lock Screen" { spawn-sh "dms ipc call lock lock"; }
    Ctrl+Alt+Escape { spawn-sh "dms ipc call lock lock"; }
    Mod+X hotkey-overlay-title="Power Menu" { spawn-sh "dms ipc call powermenu toggle"; }
    Mod+Shift+K { spawn "thunar"; }
    Mod+Shift+C hotkey-overlay-title="Clipboard Manager" { spawn-sh "dms ipc call clipboard toggle"; }
    Mod+Shift+B allow-when-locked=true { spawn-sh "dms restart"; }
    Mod+Alt+P hotkey-overlay-title="Notepad" { spawn-sh "dms ipc call notepad toggle"; }
    Mod+Alt+C hotkey-overlay-title="Control Center" { spawn-sh "dms ipc call control-center toggle"; }
    Ctrl+Alt+P { spawn "pamac-manager"; }
    Mod+Shift+M { spawn-sh "wl-present mirror"; }
    Mod+Escape { spawn-sh "kitty btop"; }
    Mod+Alt+F { spawn-sh "variety -f && notify-send 'Copied to favorites'"; }
    Mod+Alt+W { spawn-sh "variety -n && notify-send 'Next wallpaper'"; }
    Mod+Alt+S { spawn-sh "systemctl suspend"; }
    Mod+Alt+2 { spawn-sh "~/.bin/lnk_push.sh"; }
    Mod+Alt+1 { spawn-sh "~/.bin/lnk_pull.sh"; }
    Mod+Ctrl+R { spawn-sh "bash ~/.config/niri/scripts/gpu_recorder.sh"; }
    Mod+Ctrl+Slash { spawn-sh "dms ipc call keybinds toggle niri"; }
    Mod+Alt+V { spawn-sh "pavucontrol"; }
    // Cerrar la ventana activa con Mod + Clic Central
    Mod+MouseMiddle { close-window; }

    Mod+Shift+O { toggle-window-rule-opacity; }

    // Window navigation and focus
    Mod+Left { focus-column-left; }
    Mod+Down { focus-window-or-workspace-down; }
    Mod+Up { focus-window-or-workspace-up; }
    Mod+Right { focus-column-right; }
    Mod+Home { focus-column-first; }
    Mod+End { focus-column-last; }
    Mod+Tab { focus-workspace-previous; }

    // Window movement
    Mod+Ctrl+Left { move-column-left; }
    Mod+Ctrl+Down { move-window-down; }
    Mod+Ctrl+Up { move-window-up; }
    Mod+Ctrl+Right { move-column-right; }
    Mod+Ctrl+H { move-column-left; }
    Mod+Ctrl+J { move-window-down; }
    Mod+Ctrl+K { move-window-up; }
    Mod+Ctrl+L { move-column-right; }
    Mod+Ctrl+Home { move-column-to-first; }
    Mod+Ctrl+End { move-column-to-last; }
    Mod+I { consume-window-into-column; }
    Mod+O { expel-window-from-column; }
    Mod+BracketLeft { consume-or-expel-window-left; }
    Mod+BracketRight { consume-or-expel-window-right; }

    // Window resizing and layout
    Mod+R { switch-preset-column-width; }
    Mod+F { maximize-column; }
    Mod+C { center-column; }
    Mod+W { toggle-column-tabbed-display; }
    Mod+Shift+R { reset-window-height; }
    Mod+Shift+F { fullscreen-window; }
    Mod+Shift+W { expand-column-to-available-width; }
    Mod+Minus { set-column-width "-10%"; }
    Mod+Equal { set-column-width "+10%"; }
    Mod+Shift+Minus { set-window-height "-10%"; }
    Mod+Shift+Equal { set-window-height "+10%"; }
    Mod+T { toggle-window-floating; }

    // Monitor movement and focus
    Mod+Shift+Left { focus-monitor-left; }
    Mod+Shift+Down { focus-monitor-down; }
    Mod+Shift+Up { focus-monitor-up; }
    Mod+Shift+Right { focus-monitor-right; }
    Mod+Shift+Ctrl+Left { move-column-to-monitor-left; }
    Mod+Shift+Ctrl+Down { move-column-to-monitor-down; }
    Mod+Shift+Ctrl+Up { move-column-to-monitor-up; }
    Mod+Shift+Ctrl+Right { move-column-to-monitor-right; }
    Mod+Alt+Ctrl+Left { move-workspace-to-monitor-left; }
    Mod+Alt+Ctrl+Right { move-workspace-to-monitor-right; }

    // Workspace navigation
    Mod+Page_Down { focus-workspace-down; }
    Mod+Page_Up { focus-workspace-up; }
    Mod+Ctrl+Page_Down { move-column-to-workspace-down; }
    Mod+Ctrl+Page_Up { move-column-to-workspace-up; }
    Mod+Ctrl+U { move-column-to-workspace-down; }
    Mod+Ctrl+I { move-column-to-workspace-up; }
    Mod+Shift+Page_Down { move-workspace-down; }
    Mod+Shift+Page_Up { move-workspace-up; }

    // Workspace by index
    Mod+1 { focus-workspace 1; }
    Mod+2 { focus-workspace 2; }
    Mod+3 { focus-workspace 3; }
    Mod+4 { focus-workspace 4; }
    Mod+5 { focus-workspace 5; }
    Mod+6 { focus-workspace 6; }
    Mod+7 { focus-workspace 7; }
    Mod+8 { focus-workspace 8; }
    Mod+9 { focus-workspace 9; }
    Mod+Shift+1 { move-column-to-workspace 1; }
    Mod+Shift+2 { move-column-to-workspace 2; }
    Mod+Shift+3 { move-column-to-workspace 3; }
    Mod+Shift+4 { move-column-to-workspace 4; }
    Mod+Shift+5 { move-column-to-workspace 5; }
    Mod+Shift+6 { move-column-to-workspace 6; }
    Mod+Shift+7 { move-column-to-workspace 7; }
    Mod+Shift+8 { move-column-to-workspace 8; }
    Mod+Shift+9 { move-column-to-workspace 9; }

    // Screenshots
    Print { screenshot; }
    Ctrl+Print { screenshot-screen; }
    Alt+Print { screenshot-window; }
    Mod+Print { spawn "~/.config/niri/scripts/screenshot_swappy.sh"; }

    // Multimedia and peripherals

    XF86AudioRaiseVolume allow-when-locked=true { spawn-sh "dms ipc call audio increment 3"; }
    XF86AudioLowerVolume allow-when-locked=true { spawn-sh "dms ipc call audio decrement 3"; }
    XF86AudioMute allow-when-locked=true { spawn-sh "dms ipc call audio mute"; }
    XF86AudioMicMute allow-when-locked=true { spawn-sh "dms ipc call audio micmute"; }
    XF86MonBrightnessUp allow-when-locked=true { spawn "dms" "ipc" "call" "brightness" "increment" "5" ""; }
    // You can override the default device for e.g. keyboards by adding the device name to the last param
    XF86MonBrightnessDown allow-when-locked=true { spawn "dms" "ipc" "call" "brightness" "decrement" "5" ""; }
    Alt+F10 { spawn-sh "dms ipc call audio mute"; }
    Alt+F11 { spawn-sh "dms ipc call audio decrement 3"; }
    Alt+F12 { spawn-sh "dms ipc call audio increment 3"; }


    // Mouse wheel binds
    Mod+WheelScrollDown cooldown-ms=150 { focus-workspace-down; }
    Mod+WheelScrollUp cooldown-ms=150 { focus-workspace-up; }
    Mod+Ctrl+WheelScrollDown cooldown-ms=150 { move-column-to-workspace-down; }
    Mod+Ctrl+WheelScrollUp cooldown-ms=150 { move-column-to-workspace-up; }
    Mod+WheelScrollRight { focus-column-right; }
    Mod+WheelScrollLeft { focus-column-left; }
    Mod+Ctrl+WheelScrollRight { move-column-right; }
    Mod+Ctrl+WheelScrollLeft { move-column-left; }
    Mod+Shift+WheelScrollDown { focus-column-right; }
    Mod+Shift+WheelScrollUp { focus-column-left; }
    Mod+Ctrl+Shift+WheelScrollDown { move-column-right; }
    Mod+Ctrl+Shift+WheelScrollUp { move-column-left; }
    Mod+Ctrl+MouseLeft { close-window; }
    Mod+Ctrl+MouseMiddle { maximize-column; }
    Ctrl+MouseMiddle { close-window; }

    // Touchpad binds
    Mod+TouchpadScrollDown { spawn-sh "dms ipc call audio decrement 3"; }
    Mod+TouchpadScrollUp { spawn-sh "dms ipc call audio increment 3"; }

}

// Switch events
switch-events {
       lid-close { spawn "systemctl" "suspend"; }
}

